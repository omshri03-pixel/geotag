# ============================================================
#  GEO TAGGER BUZZ E — Environment Variables Reference
#  Copy this file to `.env.local` for local development.
#  Add these same keys in Vercel → Project → Settings → Environment Variables
# ============================================================


# ─────────────────────────────────────────────
# 1. DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────────

# Primary connection string (used by db.ts)
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection String → URI (Mode: Transaction)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase also provides this alias (for Vercel Postgres compatibility)
POSTGRES_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase Project Public URL (used for Supabase JS client if added later)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co

# Supabase Anonymous/Public Key (safe to expose — used client-side if needed)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (NEVER expose publicly — server-side admin operations only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Direct DB connection (for migrations, NOT for serverless use)
# Get from: Supabase Dashboard → Project → Settings → Database → Connection String → URI (Mode: Session)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres


# ─────────────────────────────────────────────
# 2. AI — NVIDIA NIM API
# ─────────────────────────────────────────────

# Your NVIDIA NIM API Key
# Get from: https://build.nvidia.com → API Keys
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA API Base URL (do not change unless using a custom deployment)
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1


# ─────────────────────────────────────────────
# 3. AUTH — Google OAuth 2.0 (if enabled)
# ─────────────────────────────────────────────

# Google OAuth Client ID
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Google OAuth Client Secret (server-side only, do NOT prefix with NEXT_PUBLIC_)
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────
# 4. APP — Site Configuration (Vercel)
# ─────────────────────────────────────────────

# The canonical public URL of your deployed app (set automatically by Vercel)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Vercel automatically injects this, but you can override:
# VERCEL_URL=your-project.vercel.app


# ─────────────────────────────────────────────
# 5. MAPBOX (optional — currently using free Leaflet/CartoDB)
# ─────────────────────────────────────────────

# If you switch MapPicker or Sandbox to use Mapbox GL JS directly:
# Get from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbHh4eHh4eHgwMDAxMmpxeXh4eHh4eHh4In0.xxxxxxxxxxxxxxxxxxxx
